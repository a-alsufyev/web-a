# OPENAI_API_KEY: Required for OpenAI GPT-4o-mini API calls.
# Users configure this via the Secrets/Settings panel in the AI Studio UI or set it on their VPS/local environment.
OPENAI_API_KEY="your-openai-api-key-here"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SMTP Secure Email Delivery Configuration
# Configure these to enable automated email alerts of new leads:
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-specific-password"
SMTP_TO="alsufyev@gmail.com"

